---
import "../styles/global.css";
---

<header class="px-4 py-5 my-5 text-center">
    <!-- <img class="d-block mx-auto mb-4" src="/docs/5.0/assets/brand/bootstrap-logo.svg" alt="" width="72" height="57" /> -->
    <h1 class="display-5 fw-medium mb-4">Exceptional Coffee, <br /> Crafted for Everyday Luxury</h1>
    <div class="col-lg-6 mx-auto">
        <p class="lead mb-4">Ethically sourced, small-batch roasted <br /> specialty coffee delivered fresh to your door.</p>
        <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
            <button type="button" class="btn btn-primary btn-lg px-4 gap-3">Shop Coffee</button>
            <button type="button" class="btn btn-secondary btn-lg px-4">Start Subscription</button>
        </div>
    </div>
</header>
