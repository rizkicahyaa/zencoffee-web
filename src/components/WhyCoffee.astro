---
import "../styles/global.css";
---

<section class="why-coffee py-5">
    <div class="container">
        <div class="row text-center mb-4">
            <h2>Why Coffee Lovers Choose Zencoffee</h2>
        </div>
        <div class="row text-center">
            <div class="col-md-3 g-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <i class="bi bi-cup-hot fs-1 mb-4"></i>
                        <p>Freshly Roasted Weekly</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 g-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <i class="bi bi-graph-up fs-1 mb-4"></i>
                        <p>Direct Trade & Ethical Sourcing</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 g-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <i class="bi bi-award fs-1 mb-4"></i>
                        <p>Award-Winning Quality</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 g-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <i class="bi bi-file-lock fs-1 mb-4"></i>
                        <p>Secure Checkout & Fast Delivery</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
